# GitHub Personal Access Token (needs 'repo' scope)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Your GitHub repo (owner/repo format)
FOREMAN_REPO=yourusername/foreman

# ─── AI Provider Keys (only need keys for providers you use) ───
# Set keys for whichever providers your routing profile uses.
# The "cheap" profile only needs GEMINI_API_KEY.
# The "balanced" profile needs both ANTHROPIC_API_KEY and GEMINI_API_KEY.

ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxx
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
# GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# ─── Routing ───
# Profiles: "cheap" (mostly Gemini), "balanced" (mix), "quality" (mostly Claude)
ROUTING_PROFILE=balanced

# ─── Agent Behavior ───
POLL_INTERVAL=60
BRAINSTORM_THRESHOLD=2
BRAINSTORM_MAX_DRAFTS=5
COST_CEILING_USD=5.0

# ─── Notifications (Optional) ───
# To enable Telegram notifications, create a bot and get the token from BotFather.
# Then, find your chat ID by sending a message to the bot and visiting:
# https://api.telegram.org/bot<YOUR_BOT_TOKEN>/getUpdates
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
